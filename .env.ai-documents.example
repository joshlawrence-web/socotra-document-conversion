# Ad-hoc rendering preview settings — copy to .env.ai-documents (gitignored).
# Process environment variables with the same names override this file.
#
# Used by:
#   python3 -m velocity_converter.render_preview ...
#   python3 tests/pipeline/run_test_pipeline.py --auto --render-preview
#
# The token needs the `documents` security group's `render-external` permission. (PAT = Personal Access Token, prefix SOCP_)
# Deploy the generated DocumentDataSnapshotPlugin to the tenant first — it
# supplies $data (conditionals included) when the renderer runs.

AI_DOCUMENTS_API_URL=https://api.example.socotra.com/
AI_DOCUMENTS_TENANT_LOCATOR=00000000-0000-0000-0000-000000000000
AI_DOCUMENTS_PAT=
AI_DOCUMENTS_PRODUCT_NAME=ZenCover

# Reference locators the test suite renders fixtures against. A fixture's
# reference type comes from its stem — TestQuoteSummary(quote) uses
# AI_DOCUMENTS_REFERENCE_QUOTE, TestItemCert(segment) uses
# AI_DOCUMENTS_REFERENCE_SEGMENT. Fixtures whose type is unset are skipped.
AI_DOCUMENTS_REFERENCE_QUOTE=
AI_DOCUMENTS_REFERENCE_SEGMENT=
#AI_DOCUMENTS_REFERENCE_POLICY=
#AI_DOCUMENTS_REFERENCE_TERM=
#AI_DOCUMENTS_REFERENCE_TRANSACTION=
#AI_DOCUMENTS_REFERENCE_INVOICE=
