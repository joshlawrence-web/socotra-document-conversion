<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="utf-8"/>
<title>Policy summary</title>
<style>
    body { font-family: sans-serif; margin: 2rem; color: #222; }
    h1 { font-size: 1.25rem; }
    table { border-collapse: collapse; width: 100%; max-width: 36rem; margin-top: 1rem; }
    th, td { border: 1px solid #ccc; padding: 0.5rem 0.75rem; text-align: left; }
    th { background: #f5f5f5; }
  </style>
</head>
<body>
<h1>Summary</h1>

#if($TBD_productName)
<p><strong>Product:</strong> $TBD_productName</p>
#end


#if($TBD_currency)
<p><strong>Currency:</strong> $TBD_currency</p>
#end


#if($TBD_policyNumber)
<p>Reference: <strong>$TBD_policyNumber</strong></p>
#end

<h2>Insureds</h2>
<table>
<thead>
<tr><th>Name</th><th>Location</th></tr>
</thead>
<tbody>
      *insureds*
      
#if($TBD_lastName and $TBD_location)
<tr>
<td>$TBD_lastName</td>
<td>$TBD_location</td>
</tr>
#end

</tbody>
</table>
<h2>Coverages</h2>
<ul>

#if($TBD_coverageName and $TBD_coverageLimit)
<li>$TBD_coverageName — $TBD_coverageLimit</li>
#end

<li>Template sibling, discarded after conversion</li>
<li>Another template sibling</li>
</ul>
</body>
</html>
