#end

            
#foreach ($named_insured in $TBD_named_insureds)

            <li>$named_insured.TBD_first_name $named_insured.TBD_last_name</li>
            
#end

    <p></p>
<hr class="dotted-line"/>
<p>
</p><h6>Financial responsibility vendor: $TBD_financial_responsibility_vendor</h6>
<h6>$TBD_financial_responsibility_phone</h6>
<p></p>
<hr class="dotted-line"/>
<p>
</p><h6>Policy Period: $TBD_policy_period_start - $TBD_policy_period_end </h6>
<p></p>
<hr class="dotted-line"/>
<p>
</p><h6>Effective date and time: $TBD_effective_date_start - $TBD_effective_date_end </h6>
<p></p>
<hr class="dotted-line"/>
<p>
</p><h6>Total policy premium: $TBD_total_policy_premium </h6>
<p></p>
<hr class="dotted-line"/>
<p>
</p><h6>Initial Payment Required:  $TBD_initial_payment_required </h6>
<p></p>
<hr class="dotted-line"/>
<p>
</p><h6>Initial Payment Received:  $TBD_initial_payment_received</h6>
<p></p>
<hr class="dotted-line"/>
<p>
</p><h6>Payment Plan: $TBD_payment_plan </h6>
<p></p>
<hr class="dotted-line"/>
<h3>Drivers and household residents</h3>
<p>
        All household residents who operate the vehicles described in the application, all operators that have an ownership
        interest in any of these vehicles and any other regular operator of these vehicles are listed below.
    </p>
<div>
<ul>
            
#foreach ($driver in $TBD_drivers)

            <li>$driver.TBD_first_name $driver.TBD_last_name<br/>
            Date of birth: $driver.TBD_date_of_birth<br/>
            Marital Status: $driver.TBD_marital_status<br/>
            License Status: $driver.TBD_license_state - $driver.TBD_license_number<br/>
            Relationship: $driver.TBD_relationship<br/><br/>
            Principle Vehicle: $driver.TBD_principal_vehicle_year $driver.TBD_principal_vehicle_make $driver.TBD_principal_vehicle_model <br/>
