<html><head><link href="https://www.w3schools.com/w3css/4/w3.css" rel="stylesheet"/>
<meta charset="utf-8"/>
<title>Policy Document</title>
<style>
        body {
            font-family: Arial, sans-serif;
            margin: 30px;
            line-height: 1.4;
        }
        .sectionTitle {
            font-weight: bold;
            font-size: 1.2em;
            margin-top: 20px;
        }
        .pageBreak {
            page-break-before: always;
        }
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1em;
        }
        .policy-info {
            text-align: right;
            font-size: 10pt;
            line-height: 1.2;
        }
        .app-info {
            text-align: left;
            font-size: 10pt;
            line-height: 1.2;
        }
        .logo {
            text-align: right;
            font-weight: bold;
            font-size: 16pt;
        }
        .dotted-line {
            border: none;
            border-top: 1px dotted #888;
            margin: 1em 0;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin: 1em 0;
        }
        th, td {
            text-align: left;
            vertical-align: top;
            padding: 4px 6px;
        }
        h1, h2, h3, h4 {
            margin-bottom: 6px;
            margin-top: 24px;
        }
        @page{
            counter-increment: page;
            @top-right{
                content: "Policy Number: " "$TBD_policy_number " "\A"
                            "Insured: " "$TBD_insured_first_name " "$TBD_insured_last_name " "\A"
                            "Page " counter(page) " / " counter(pages);
                font-size: 10pt;
                white-space: pre;
            }
        }
    </style>
</head>
<body>
<!-- PAGE 1 -->
<p>
</p><div class="logo"><span style="float: right">Logo</span></div>
<p></p>
<div class="page-header">
<div class="app-info">
<h1> Application for Insurance</h1>
<p>Please review, sign where indicated and return.</p>
</div>
</div>

#if($TBD_policy_number)
<h4>Policy and premium information for policy number $TBD_policy_number</h4>
#end

<hr class="dotted-line"/>
<p>
</p>
#if($TBD_insurance_company)
<h6>Insurance company: $TBD_insurance_company</h6>
#end

        $TBD_insurer_address_line_1 <br/>
        $TBD_insurer_address_line_2 <br/>
<p></p>
<hr class="dotted-line"/>
<p>
</p>
#if($TBD_broker_name)
<h6>Broker/Agent: $TBD_broker_name</h6>
#end

