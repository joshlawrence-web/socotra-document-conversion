# Python
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store
.cursor/.DS_Store

# Office lock/temp files
~$*

# Pipeline actual/ outputs (test run artefacts, not golden)
conformance/fixtures/*/actual/

# Generated pipeline output — not source, don't track
workspace/output/
# Human-fill files (conditional forms, variant CSVs, path reviews) — generated, don't track
workspace/action-needed/

# Test pipeline runtime output — not source, don't track
tests/pipeline/output/
tests/pipeline/action-needed/

# Live-tenant render-preview credentials — example is committed
.env.ai-documents

# Build artifacts
build/

# IDE
.vscode/

# Archived plans (kept in git history only)
.cursor/plans/

# Packaging
*.egg-info/

*.bak

# Live customer prod data — never commit
workspace-prod/
